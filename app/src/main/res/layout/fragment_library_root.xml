<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fillViewport="true">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CouchFi"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/root_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="18sp"
        android:paddingBottom="32dp" />

    <Button
        android:id="@+id/root_artists"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:text="Artists"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:background="@drawable/button_focus_bg" />

    <Button
        android:id="@+id/root_albums"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:text="Albums"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:background="@drawable/button_focus_bg" />

    <Button
        android:id="@+id/root_songs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:text="Songs"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:background="@drawable/button_focus_bg" />

    <Button
        android:id="@+id/root_radio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:padding="16dp"
        android:layout_marginBottom="32dp"
        android:text="Internet Radio"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:background="@drawable/button_focus_bg" />

    <Button
        android:id="@+id/root_rescan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:padding="12dp"
        android:text="Rescan Library"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="@drawable/button_focus_bg" />
</LinearLayout>
</ScrollView>
